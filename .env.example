# =============================================================
# Aesthete E-Commerce – Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# =============================================================

# Supabase Project URL (from: Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Publishable Key (from: Project Settings → API → anon/public key)
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here
